          "text": [
            "Duplicate rows removed: 32,343  (6.47% of dataset)\n",
            "Shape after deduplication: (467650, 82)\n"
          ]
        }
      ],
      "source": [
        "n_before = len(df)\n",
        "df = df.drop_duplicates(subset=numeric_cols)\n",
        "n_removed = n_before - len(df)\n",
        "print(f'Duplicate rows removed: {n_removed:,}  ({n_removed/n_before*100:.2f}% of dataset)')\n",
        "print(f'Shape after deduplication: {df.shape}')"
      ]
    },
