      },
      "source": [
        "### 3.3 Drop Zero-Variance & Near-Zero-Variance Features"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "QJLdB_wRkuG0",
        "outputId": "94875eaf-719e-4f92-a8bd-4e76d8611d2a"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Zero-variance columns    : ['Bwd PSH Flags', 'Bwd URG Flags', 'Fwd Avg Bytes/Bulk', 'Fwd Avg Packets/Bulk', 'Fwd Avg Bulk Rate', 'Bwd Avg Bytes/Bulk', 'Bwd Avg Packets/Bulk', 'Bwd Avg Bulk Rate']\n",
            "Near-zero-variance cols  : ['Fwd URG Flags', 'RST Flag Count', 'CWE Flag Count', 'ECE Flag Count']\n",
            "Total columns to drop    : 12\n",
            "Remaining numeric features: 66\n"
          ]
        }
      ],
      "source": [
        "zero_var_cols = [c for c in numeric_cols if df[c].nunique() <= 1]\n",
        "near_zero_var = [\n",
        "    c for c in numeric_cols\n",
        "    if df[c].nunique() > 1 and df[c].value_counts(normalize=True).iloc[0] > 0.99\n",
        "]\n",
        "\n",
        "cols_to_drop = list(set(zero_var_cols + near_zero_var))\n",
        "print(f'Zero-variance columns    : {zero_var_cols}')\n",
        "print(f'Near-zero-variance cols  : {near_zero_var}')\n",
        "print(f'Total columns to drop    : {len(cols_to_drop)}')\n",
        "\n",
        "df.drop(columns=cols_to_drop, inplace=True)\n",
        "numeric_cols = [c for c in numeric_cols if c not in cols_to_drop]\n",
        "feature_cols = [c for c in feature_cols if c not in cols_to_drop]\n",
        "\n",
        "print(f'Remaining numeric features: {len(numeric_cols)}')"
      ]
    },
