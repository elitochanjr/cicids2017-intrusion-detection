    {
      "cell_type": "markdown",
      "metadata": {
        "id": "-xmK7nw4kuG0"
      },
      "source": [
        "### 3.5 Handle Infinite Values"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "MrOrm5aBkuG1",
        "outputId": "f0a67d12-7fe6-40af-8a8d-cc5e956c1e04"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Columns with Inf values treated: 2\n",
            "  Flow Bytes/s: 234 Inf values capped at 99.9th percentile\n",
            "  Flow Packets/s: 234 Inf values capped at 99.9th percentile\n",
            "\n",
            "Remaining Inf values: 0\n"
          ]
        }
      ],
      "source": [
        "# Flow Bytes/s and Flow Packets/s produce Inf when flow duration = 0\n",
        "# Strategy: cap at the 99.9th percentile of finite values for each column\n",
        "\n",
        "inf_cols = []\n",
        "for col in numeric_cols:\n",
        "    n_inf = np.isinf(df[col]).sum()\n",
        "    if n_inf > 0:\n",
        "        inf_cols.append((col, n_inf))\n",
        "        finite_vals = df.loc[np.isfinite(df[col]), col]\n",
        "        cap_val = finite_vals.quantile(0.999) if len(finite_vals) > 0 else 0\n",
        "        df[col] = df[col].replace([np.inf, -np.inf], cap_val)\n",
        "\n",
        "print(f'Columns with Inf values treated: {len(inf_cols)}')\n",
        "for col, n in inf_cols:\n",
        "    print(f'  {col}: {n:,} Inf values capped at 99.9th percentile')\n",
        "\n",
        "# Final check\n",
        "remaining_inf = sum(np.isinf(df[c]).sum() for c in numeric_cols)\n",
        "print(f'\\nRemaining Inf values: {remaining_inf}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "WossQeDBkuG1"
      },
      "source": [
        "### 3.6 Log Transform Highly Skewed Features\n",
        "\n",
        "Rate and count features show extreme right skew driven by attack traffic. Log1p transformation compresses the scale without losing the signal."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "PfQbCB-zkuG1",
        "outputId": "39b08e2f-18d6-44f0-ea2c-d7d8b82a42f3"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Features with |skewness| > 5: 39\n",
            "Fwd Header Length             660.3864\n",
            "Fwd Header Length.1           660.3864\n",
            "Total Length of Fwd Packets   576.6844\n",
            "Subflow Fwd Bytes             576.2758\n",
            "Bwd Header Length             390.2363\n",
            "min_seg_size_forward          297.9641\n",
            "act_data_pkt_fwd              254.6137\n",
            "Subflow Bwd Bytes             253.6265\n",
            "Total Length of Bwd Packets   253.6258\n",
            "Total Backward Packets        253.3691\n",
            "Subflow Bwd Packets           253.3691\n",
            "Subflow Fwd Packets           253.2678\n",
            "Total Fwd Packets             253.2678\n",
            "Flow Bytes/s                   43.4280\n",
            "Active Std                     40.1854\n",
            "dtype: float64\n",
            "\n",
            "Log1p applied to 29 features.\n"
          ]
        }
      ],
      "source": [
        "# Compute skewness for all non-negative numeric features\n",
        "skewness = df[numeric_cols].skew().abs()\n",
        "high_skew_cols = skewness[skewness > 5].index.tolist()\n",
        "\n",
        "print(f'Features with |skewness| > 5: {len(high_skew_cols)}')\n",
        "print(skewness[high_skew_cols].sort_values(ascending=False).head(15))\n",
        "\n",
        "# Apply log1p to all highly skewed, non-negative columns\n",
        "log_transformed = []\n",
        "for col in high_skew_cols:\n",
        "    if df[col].min() >= 0:  # log1p safe for non-negative values\n",
        "        df[col] = np.log1p(df[col].astype(float))\n",
        "        log_transformed.append(col)\n",
        "\n",
        "print(f'\\nLog1p applied to {len(log_transformed)} features.')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "QtinaTNWkuG1"
      },
      "source": [
        "### 3.7 Robust Scaling\n",
        "\n",
        "RobustScaler uses the median and IQR — it's resistant to the remaining outliers in attack traffic features, unlike StandardScaler which can be pulled by extreme values."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 12,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aEnPR04zkuG1",
        "outputId": "4f1d60cd-e384-475f-8117-61d380b6ac4d"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "RobustScaler fitted and saved to ./models/robust_scaler.pkl\n",
            "Scaled feature matrix shape: (467589, 66)\n"
          ]
        }
      ],
      "source": [
        "scaler = RobustScaler()\n",
        "df_scaled = df[numeric_cols].copy()\n",
        "df_scaled[numeric_cols] = scaler.fit_transform(df_scaled[numeric_cols])\n",
        "\n",
        "# Save scaler for reproducibility\n",
        "os.makedirs('./models', exist_ok=True)\n",
        "joblib.dump(scaler, './models/robust_scaler.pkl')\n",
        "print('RobustScaler fitted and saved to ./models/robust_scaler.pkl')\n",
        "print(f'Scaled feature matrix shape: {df_scaled.shape}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "O46Qnw67kuG1"
      },
      "source": [
        "## 4. Feature Engineering\n",
        "\n",
        "Domain knowledge about network traffic allows construction of derived features that capture attack patterns more directly than raw CICFlowMeter columns."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "L06UQfAfkuG1",
        "outputId": "4d7398c1-a503-4a3f-843e-94054ac36316"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Created: byte_asymmetry\n",
            "Created: pkt_asymmetry\n",
            "Created: flag_intensity (from ['SYN Flag Count', 'FIN Flag Count'])\n",
            "Created: payload_header_ratio_fwd\n",
            "Created: duration_bin (0=zero, 1=<1ms, 2=<100ms, 3=<1s, 4=>=1s)\n",
            "\n",
            "Total features after engineering: 71\n",
            "Engineered features added: ['byte_asymmetry', 'pkt_asymmetry', 'flag_intensity', 'payload_header_ratio_fwd', 'duration_bin']\n"
          ]
        }
      ],
      "source": [
        "# ── 4.1 Byte Asymmetry Ratio ──────────────────────────────────────────────────\n",
        "# Legitimate TCP connections are roughly bidirectional; attack flows (DoS, scans)\n",
        "# are heavily one-directional. Ratio: (fwd - bwd) / (fwd + bwd + epsilon)\n",
        "\n",
        "if 'Total Length of Fwd Packets' in df.columns and 'Total Length of Bwd Packets' in df.columns:\n",
        "    fwd_bytes = df['Total Length of Fwd Packets'].astype(float)\n",
        "    bwd_bytes = df['Total Length of Bwd Packets'].astype(float)\n",
        "    df['byte_asymmetry'] = (fwd_bytes - bwd_bytes) / (fwd_bytes + bwd_bytes + 1e-6)\n",
        "    df_scaled['byte_asymmetry'] = df['byte_asymmetry']\n",
        "    print('Created: byte_asymmetry')\n",
        "\n",
        "# ── 4.2 Packet Asymmetry Ratio ────────────────────────────────────────────────\n",
        "if 'Total Fwd Packets' in df.columns and 'Total Backward Packets' in df.columns:\n",
        "    fwd_pkts = df['Total Fwd Packets'].astype(float)\n",
        "    bwd_pkts = df['Total Backward Packets'].astype(float)\n",
        "    df['pkt_asymmetry'] = (fwd_pkts - bwd_pkts) / (fwd_pkts + bwd_pkts + 1e-6)\n",
        "    df_scaled['pkt_asymmetry'] = df['pkt_asymmetry']\n",
        "    print('Created: pkt_asymmetry')\n",
        "\n",
        "# ── 4.3 TCP Flag Intensity ────────────────────────────────────────────────────\n",
        "# Sum of aggressive TCP flags (SYN, RST, FIN) normalised by total packets.\n",
        "# High values suggest SYN floods, RST storms, or aggressive scanners.\n",
        "flag_cols_available = [c for c in ['SYN Flag Count', 'RST Flag Count', 'FIN Flag Count'] if c in df.columns]\n",
        "pkt_total = df.get('Total Fwd Packets', pd.Series(0, index=df.index)).astype(float) + \\\n",
        "            df.get('Total Backward Packets', pd.Series(0, index=df.index)).astype(float)\n",
        "\n",
        "if flag_cols_available:\n",
        "    df['flag_intensity'] = df[flag_cols_available].sum(axis=1) / (pkt_total + 1e-6)\n",
        "    df_scaled['flag_intensity'] = df['flag_intensity']\n",
        "    print(f'Created: flag_intensity (from {flag_cols_available})')\n",
        "\n",
        "# ── 4.4 Payload Ratio (data content vs header overhead) ──────────────────────\n",
        "if all(c in df.columns for c in ['Total Length of Fwd Packets', 'Fwd Header Length']):\n",
        "    fwd_payload = df['Total Length of Fwd Packets'].astype(float)\n",
  