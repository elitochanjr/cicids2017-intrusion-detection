        "## 3. Preprocessing\n",
        "\n",
        "### 3.1 Define Feature Columns"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
